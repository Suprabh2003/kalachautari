client/public/index.html<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Kalachautari — कलाचौतारी</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Tiro+Devanagari+Nepali:ital@0;1&family=Mukta:wght@300;400;600;700&family=Yatra+One&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --rust:#B8432F;--rust2:#8C2E1A;--rust-light:#FAF0EC;
  --cream:#FBF6EE;--cream2:#F4ECD8;--cream3:#EDE0C8;
  --ink:#1A0F08;--muted:#6B4F3A;--muted2:#9B7B60;
  --gold:#C9922A;--gold2:#A87820;--gold-light:#FDF5E6;
  --himalaya:#1E4D7A;--himalaya2:#163A5E;--himalaya-light:#EAF1F8;
  --green:#2A6B3C;--green-light:#EAF4EE;
  --border:rgba(26,15,8,0.12);--border2:rgba(26,15,8,0.06);
  --card:#FFFCF7;
}
body{font-family:'Mukta',sans-serif;background:var(--cream);color:var(--ink);font-size:14px;line-height:1.5}
.np{font-family:'Tiro Devanagari Nepali','Mukta',sans-serif}
.yatra{font-family:'Yatra One','Tiro Devanagari Nepali',serif}
.en-t{display:inline}
.np-t{display:none}
body.nepali .en-t{display:none}
body.nepali .np-t{display:inline}

/* ── LAYOUT ── */
#app{display:none}
#auth-screen{display:flex;min-height:100vh;align-items:center;justify-content:center;background:var(--ink);padding:1rem}

/* ── AUTH ── */
.auth-box{background:var(--cream);border-radius:8px;width:100%;max-width:420px;overflow:hidden}
.auth-header{background:var(--ink);padding:1.5rem;text-align:center;border-bottom:3px solid var(--gold)}
.auth-tabs{display:flex;border-bottom:1px solid var(--border)}
.auth-tab{flex:1;background:none;border:none;padding:0.875rem;font-family:'Mukta',sans-serif;font-size:0.85rem;cursor:pointer;color:var(--muted);border-bottom:2px solid transparent;transition:all 0.15s}
.auth-tab.act{color:var(--rust);border-bottom-color:var(--rust);font-weight:700}
.auth-form{padding:1.25rem;display:none}
.auth-form.act{display:block}
.auth-form .fgrp{margin-bottom:0.875rem}
.auth-form .flbl{font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.4px;color:var(--muted);margin-bottom:4px;display:block}
.auth-form .finp{width:100%;border:1px solid var(--border);border-radius:3px;padding:8px 12px;font-family:'Mukta',sans-serif;font-size:0.85rem;background:var(--card);color:var(--ink)}
.auth-form .finp:focus{outline:none;border-color:var(--rust)}
.auth-err{color:var(--rust);font-size:0.78rem;margin-bottom:0.5rem;min-height:18px}
.demo-hint{font-size:0.72rem;color:var(--muted);text-align:center;margin-top:0.75rem;padding:6px 10px;background:var(--cream2);border-radius:3px}

/* ── NAV ── */
#nav{background:var(--ink);padding:0 1.25rem;display:flex;align-items:center;height:54px;border-bottom:3px solid var(--gold);gap:0.25rem;position:sticky;top:0;z-index:100}
.logo{display:flex;align-items:center;gap:7px;text-decoration:none;margin-right:0.5rem}
.logo-icon{width:32px;height:32px;background:var(--rust);border-radius:3px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:15px;flex-shrink:0}
.logo-txt{color:#fff;font-size:1.1rem;line-height:1}
.logo-sub{color:var(--gold);font-size:0.58rem;letter-spacing:1px;text-transform:uppercase}
.nav-btn{background:none;border:none;cursor:pointer;color:rgba(255,255,255,0.65);font-size:0.78rem;padding:5px 9px;border-radius:3px;font-family:'Mukta',sans-serif;transition:all 0.15s;white-space:nowrap;position:relative}
.nav-btn:hover{color:#fff;background:rgba(255,255,255,0.08)}
.nav-btn.act{color:#fff;background:rgba(255,255,255,0.12);font-weight:700}
.nav-badge{position:absolute;top:2px;right:2px;background:var(--rust);color:#fff;font-size:0.55rem;padding:1px 4px;border-radius:8px;min-width:14px;text-align:center}
.lang-tog{display:flex;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.13);border-radius:14px;padding:3px;margin-left:auto}
.lng{background:none;border:none;cursor:pointer;color:rgba(255,255,255,0.5);font-size:0.68rem;padding:2px 8px;border-radius:10px;font-family:'Mukta',sans-serif;transition:all 0.2s}
.lng.act{background:var(--rust);color:#fff}
.nav-user{display:flex;align-items:center;gap:6px;color:rgba(255,255,255,0.7);font-size:0.75rem;padding:0 6px}
.nav-av{width:28px;height:28px;border-radius:50%;background:var(--rust);display:flex;align-items:center;justify-content:center;font-size:0.72rem;font-weight:700;color:#fff;cursor:pointer}

/* ── PAGES ── */
.page{display:none;padding:1.25rem 1.5rem;max-width:1200px;margin:0 auto}
.page.act{display:block}

/* ── BUTTONS ── */
.btn-p{background:var(--rust);color:#fff;border:none;padding:7px 16px;border-radius:3px;font-family:'Mukta',sans-serif;font-size:0.8rem;font-weight:700;cursor:pointer;transition:background 0.15s}
.btn-p:hover{background:var(--rust2)}
.btn-p:disabled{opacity:0.5;cursor:not-allowed}
.btn-o{background:none;color:var(--ink);border:1px solid var(--border);padding:6px 14px;border-radius:3px;font-family:'Mukta',sans-serif;font-size:0.8rem;cursor:pointer;transition:all 0.15s}
.btn-o:hover{border-color:var(--rust);color:var(--rust)}
.btn-g{background:var(--gold);color:var(--ink);border:none;padding:6px 14px;border-radius:3px;font-family:'Mukta',sans-serif;font-size:0.8rem;font-weight:700;cursor:pointer}
.btn-g:hover{background:var(--gold2);color:#fff}
.btn-sm{background:none;color:var(--ink);border:1px solid var(--border);padding:3px 9px;border-radius:3px;font-family:'Mukta',sans-serif;font-size:0.72rem;cursor:pointer;transition:all 0.15s}
.btn-sm:hover{border-color:var(--rust);color:var(--rust)}

/* ── CARDS ── */
.card{background:var(--card);border:1px solid var(--border);border-radius:6px;transition:border-color 0.15s}
.card:hover{border-color:rgba(184,67,47,0.4)}
.sec-title{font-family:'Yatra One',serif;font-size:1.2rem;color:var(--ink);margin-bottom:1rem;display:flex;align-items:center;gap:8px}
.sec-title::after{content:'';flex:1;height:1px;background:var(--border)}
.fbar{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:1rem;align-items:center}
.fpill{background:var(--card);border:1px solid var(--border);color:var(--muted);font-size:0.72rem;padding:4px 12px;border-radius:14px;cursor:pointer;font-family:'Mukta',sans-serif;transition:all 0.15s}
.fpill:hover,.fpill.act{background:var(--rust);color:#fff;border-color:var(--rust)}
.srch{border:1px solid var(--border);border-radius:3px;padding:5px 10px;font-family:'Mukta',sans-serif;font-size:0.8rem;background:var(--card);color:var(--ink);min-width:180px}
.srch:focus{outline:none;border-color:var(--rust)}
.tag{background:var(--cream2);color:var(--muted);font-size:0.67rem;padding:2px 6px;border-radius:2px;font-weight:600;display:inline-block}
.tag.rust{background:var(--rust-light);color:var(--rust2)}
.tag.gold{background:var(--gold-light);color:var(--gold2)}
.tag.blue{background:var(--himalaya-light);color:var(--himalaya2)}
.tag.green{background:var(--green-light);color:var(--green)}
.g3{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:1rem}
.g2{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:1rem}

/* ── CREATOR CARD ── */
.cc-banner{height:58px;position:relative;overflow:hidden}
.cc-banner.rust{background:var(--rust2)}.cc-banner.blue{background:var(--himalaya2)}.cc-banner.gold{background:var(--gold2)}.cc-banner.green{background:var(--green)}
.cc-pat{position:absolute;inset:0;opacity:0.15;background-image:repeating-linear-gradient(45deg,#fff 0,#fff 1px,transparent 0,transparent 8px);background-size:8px 8px}
.cc-av{width:44px;height:44px;border-radius:50%;border:3px solid var(--card);background:var(--cream2);position:absolute;bottom:-22px;left:1rem;display:flex;align-items:center;justify-content:center;font-family:'Yatra One',serif;font-size:1rem;color:var(--rust);font-weight:700}
.cc-body{padding:1.5rem 1rem 1rem}
.cc-name{font-weight:700;font-size:0.9rem}
.cc-role{font-size:0.7rem;color:var(--rust);font-weight:700;text-transform:uppercase;letter-spacing:0.4px;margin-bottom:3px}
.cc-bio{font-size:0.75rem;color:var(--muted);line-height:1.4;margin-bottom:7px}
.cc-foot{display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--border);padding-top:7px;margin-top:7px}
.cc-loc{font-size:0.68rem;color:var(--muted2)}

/* ── PROJECT CARD ── */
.pc-head{padding:0.875rem 1rem;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:flex-start;gap:8px}
.pc-title{font-weight:700;font-size:0.88rem;margin-bottom:2px}
.pc-body{padding:0.75rem 1rem}
.pc-desc{font-size:0.77rem;color:var(--muted);line-height:1.4;margin-bottom:7px}
.need{display:inline-block;background:var(--rust);color:#fff;font-size:0.63rem;padding:2px 7px;border-radius:10px;margin:2px;opacity:0.88}
.pc-foot{display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--border);padding:7px 1rem}
.ow-av{width:24px;height:24px;border-radius:50%;background:var(--cream2);display:flex;align-items:center;justify-content:center;font-size:0.6rem;font-weight:700;color:var(--rust);flex-shrink:0}

/* ── SWIPE ── */
.swipe-stack{position:relative;width:320px;height:440px;margin:0 auto}
.swipe-card{position:absolute;inset:0;background:var(--card);border:1px solid var(--border);border-radius:10px;overflow:hidden;transition:transform 0.3s,opacity 0.3s;user-select:none}
.swipe-card.gone-l{transform:translateX(-130%) rotate(-15deg);opacity:0;pointer-events:none}
.swipe-card.gone-r{transform:translateX(130%) rotate(15deg);opacity:0;pointer-events:none}
.swipe-card.back{transform:scale(0.97) translateY(8px);z-index:0}
.swipe-card.front{z-index:1}
.sw-banner{height:90px;position:relative}
.sw-av{width:52px;height:52px;border-radius:50%;border:3px solid var(--card);background:var(--cream2);position:absolute;bottom:-26px;left:1.25rem;display:flex;align-items:center;justify-content:center;font-family:'Yatra One',serif;font-size:1.1rem;color:var(--rust)}
.sw-info{padding:1.75rem 1.25rem 1.25rem}
.sw-name{font-weight:700;font-size:1rem;margin-bottom:2px}
.sw-role{font-size:0.72rem;color:var(--rust);font-weight:700;text-transform:uppercase;letter-spacing:0.4px;margin-bottom:6px}
.match-score{background:var(--gold-light);border:1px solid rgba(201,146,42,0.3);border-radius:3px;padding:5px 9px;font-size:0.75rem;margin-bottom:8px}
.match-score strong{color:var(--gold2)}
.sw-actions{display:flex;justify-content:center;gap:14px;margin-top:1rem}
.sw-btn{width:50px;height:50px;border-radius:50%;border:2px solid;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:1.1rem;background:var(--card);transition:all 0.15s}
.sw-btn.pass{border-color:var(--muted);color:var(--muted)}.sw-btn.pass:hover{background:var(--cream2)}
.sw-btn.conn{border-color:var(--rust);color:var(--rust)}.sw-btn.conn:hover{background:var(--rust-light)}
.sw-btn.star{border-color:var(--gold);color:var(--gold)}.sw-btn.star:hover{background:var(--gold-light)}
.match-pop{background:var(--ink);color:#fff;border-radius:8px;padding:1.5rem;text-align:center}
.match-pop .mp-t{font-family:'Yatra One',serif;font-size:1.4rem;color:var(--gold);margin-bottom:4px}

/* ── EVENTS ── */
.ev-card{background:var(--card);border:1px solid var(--border);border-radius:6px;display:flex;overflow:hidden;transition:border-color 0.15s}
.ev-card:hover{border-color:var(--gold)}
.ev-date{min-width:64px;background:var(--rust);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:0.75rem 0.5rem;color:#fff;flex-shrink:0}
.ev-day{font-family:'Yatra One',serif;font-size:1.7rem;line-height:1}
.ev-mon{font-size:0.62rem;text-transform:uppercase;letter-spacing:1px;opacity:0.85}
.ev-body{padding:0.875rem 1rem;flex:1}
.ev-title{font-weight:700;font-size:0.87rem;margin-bottom:3px}
.ev-meta{font-size:0.73rem;color:var(--muted);margin-bottom:5px}
.ev-act{display:flex;flex-direction:column;justify-content:center;padding:0.75rem;gap:5px;border-left:1px solid var(--border);min-width:80px}

/* ── TICKET MODAL ── */
.overlay{position:fixed;inset:0;background:rgba(26,15,8,0.6);display:flex;align-items:center;justify-content:center;z-index:200;padding:1rem}
.modal{background:var(--card);border-radius:8px;width:100%;max-width:440px;overflow:hidden}
.modal-hd{background:var(--ink);padding:1.25rem;color:#fff}
.modal-hd h3{font-family:'Yatra One',serif;color:var(--gold);font-size:1.05rem}
.modal-hd p{font-size:0.75rem;color:rgba(255,255,255,0.6);margin-top:3px}
.modal-body{padding:1.25rem}
.modal-foot{padding:0.875rem 1.25rem;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:8px}
.tkt-tier{border:1px solid var(--border);border-radius:4px;padding:9px 12px;margin-bottom:7px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;transition:border-color 0.15s}
.tkt-tier:hover,.tkt-tier.sel{border-color:var(--rust);background:var(--rust-light)}
.tkt-tier-n{font-weight:700;font-size:0.83rem}
.tkt-tier-d{font-size:0.7rem;color:var(--muted)}
.tkt-price{font-weight:700;color:var(--rust);font-size:0.87rem}

/* ── MESSAGES ── */
.msg-wrap{border:1px solid var(--border);border-radius:6px;overflow:hidden;background:var(--card)}
.msg-layout{display:grid;grid-template-columns:220px 1fr;height:520px}
.conv-list{border-right:1px solid var(--border);overflow-y:auto;background:var(--card);display:flex;flex-direction:column}
.conv-list-hd{padding:0.75rem 0.875rem;font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;color:var(--muted);border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center}
.ci{padding:0.75rem 0.875rem;border-bottom:1px solid var(--border2);cursor:pointer;transition:background 0.1s}
.ci:hover{background:var(--cream2)}
.ci.act{background:var(--cream2);border-left:3px solid var(--rust)}
.ci-name{font-size:0.8rem;font-weight:700}
.ci-prev{font-size:0.68rem;color:var(--muted);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:160px}
.ci-t{font-size:0.62rem;color:var(--muted2)}
.chat-main{display:flex;flex-direction:column}
.chat-hd{padding:0.75rem 1rem;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px;flex-shrink:0}
.chat-av{width:30px;height:30px;border-radius:50%;background:var(--cream2);display:flex;align-items:center;justify-content:center;font-size:0.63rem;font-weight:700;color:var(--rust);flex-shrink:0}
.chat-av.grp{background:var(--himalaya-light);color:var(--himalaya2)}
.chat-msgs{flex:1;padding:0.875rem;overflow-y:auto;display:flex;flex-direction:column;gap:7px;background:var(--cream)}
.msg{max-width:72%}
.msg.out{align-self:flex-end}
.mbub{padding:6px 10px;border-radius:6px;font-size:0.78rem;line-height:1.4}
.msg.in .mbub{background:var(--card);color:var(--ink)}
.msg.out .mbub{background:var(--rust);color:#fff}
.msg.sys{align-self:center;max-width:90%}
.msg.sys .mbub{background:var(--cream2);color:var(--muted);font-size:0.68rem;text-align:center;border-radius:10px}
.mt{font-size:0.6rem;color:var(--muted2);margin-top:2px}
.msg.out .mt{text-align:right}
.chat-inp{border-top:1px solid var(--border);padding:0.5rem;display:flex;gap:5px;flex-shrink:0}
.chat-inp input{flex:1;border:1px solid var(--border);border-radius:3px;padding:6px 9px;font-size:0.78rem;font-family:'Mukta',sans-serif;background:var(--cream);color:var(--ink)}
.chat-inp input:focus{outline:none;border-color:var(--rust)}
.chat-send{background:var(--rust);color:#fff;border:none;padding:6px 12px;border-radius:3px;cursor:pointer;font-size:0.75rem}
.empty-conv{display:flex;flex-direction:column;align-items:center;justify-content:center;flex:1;color:var(--muted);font-size:0.85rem;gap:8px;padding:2rem}

/* ── INTEREST MODAL ── */
.fgrp{margin-bottom:0.875rem}
.flbl{font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.4px;color:var(--muted);margin-bottom:4px;display:block}
.finp{width:100%;border:1px solid var(--border);border-radius:3px;padding:7px 10px;font-family:'Mukta',sans-serif;font-size:0.82rem;background:var(--card);color:var(--ink)}
.finp:focus{outline:none;border-color:var(--rust)}
textarea.finp{height:75px;resize:none}
select.finp{cursor:pointer}
.role-pick{display:flex;flex-wrap:wrap;gap:5px;margin-top:3px}
.rp-btn{border:1px solid var(--border);background:var(--card);color:var(--muted);font-size:0.7rem;padding:3px 9px;border-radius:12px;cursor:pointer;font-family:'Mukta',sans-serif;transition:all 0.15s}
.rp-btn.sel{background:var(--rust);color:#fff;border-color:var(--rust)}

/* ── NOTIFICATIONS ── */
.notif-item{display:flex;gap:9px;padding:0.875rem 1rem;border-bottom:1px solid var(--border);background:var(--card);cursor:pointer;transition:background 0.1s}
.notif-item:hover{background:var(--cream2)}
.notif-item.unr{background:#FFFAF2}
.n-dot{width:6px;height:6px;border-radius:50%;background:var(--rust);margin-top:5px;flex-shrink:0}
.n-dot.r{background:transparent;border:1px solid var(--border)}
.n-av{width:30px;height:30px;border-radius:50%;background:var(--cream2);display:flex;align-items:center;justify-content:center;font-size:0.68rem;font-weight:700;color:var(--rust);flex-shrink:0}

/* ── PROFILE ── */
.prof-wrap{display:grid;grid-template-columns:260px 1fr;gap:1.25rem}
.prof-side{background:var(--card);border:1px solid var(--border);border-radius:6px;overflow:hidden}
.prof-banner{height:80px;background:var(--ink);position:relative}
.prof-pat{position:absolute;inset:0;opacity:0.2;background-image:repeating-linear-gradient(60deg,var(--gold) 0,var(--gold) 1px,transparent 0,transparent 8px)}
.prof-av{width:64px;height:64px;border-radius:50%;border:4px solid var(--card);background:var(--cream2);position:absolute;bottom:-32px;left:50%;transform:translateX(-50%);display:flex;align-items:center;justify-content:center;font-family:'Yatra One',serif;font-size:1.3rem;color:var(--rust)}
.prof-info{padding:2.25rem 1rem 1rem;text-align:center}
.p-stats{display:grid;grid-template-columns:1fr 1fr 1fr;border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
.ps-box{padding:0.625rem;text-align:center}
.ps-n{font-weight:700;font-size:1rem}
.ps-l{font-size:0.6rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.4px}
.p-sec{padding:0.875rem 1rem;border-bottom:1px solid var(--border)}
.p-sec-t{font-size:0.64rem;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;color:var(--muted);margin-bottom:6px}
.sk-bar{margin-bottom:5px}
.sk-n{font-size:0.73rem;display:flex;justify-content:space-between;margin-bottom:2px}
.sk-track{height:3px;background:var(--cream2);border-radius:2px}
.sk-fill{height:100%;background:var(--rust);border-radius:2px}

/* ── TOAST ── */
#toast{position:fixed;bottom:1.5rem;right:1.5rem;background:var(--ink);color:#fff;padding:10px 16px;border-radius:5px;font-size:0.82rem;z-index:300;opacity:0;transform:translateY(10px);transition:all 0.3s;pointer-events:none;border-left:3px solid var(--gold);max-width:300px}
#toast.show{opacity:1;transform:translateY(0)}

/* ── FORM STEPS ── */
.step-ind{display:flex;gap:4px;margin-bottom:1.25rem}
.step-dot{flex:1;height:3px;background:var(--border);border-radius:2px;transition:background 0.3s}
.step-dot.done{background:var(--rust)}
.step-dot.cur{background:var(--gold)}
.form-step{display:none}
.form-step.act{display:block}
.form-nav{display:flex;justify-content:space-between;margin-top:1rem;padding-top:0.875rem;border-top:1px solid var(--border)}

/* ── HERO ── */
.hero{background:var(--ink);padding:2.5rem 1.5rem;margin:-1.25rem -1.5rem 1.25rem;border-bottom:3px solid var(--gold);display:grid;grid-template-columns:1fr 280px;gap:2rem;align-items:center}
.hero h1{font-family:'Yatra One',serif;font-size:2rem;color:#fff;line-height:1.1;margin-bottom:0.5rem}
.hero h1 span{color:var(--gold)}

/* ── LOADING ── */
.loading{text-align:center;padding:2rem;color:var(--muted);font-size:0.85rem}
.loading::after{content:'...';animation:dots 1s infinite}
@keyframes dots{0%,100%{content:'...'}33%{content:'.'}66%{content:'...'}}
</style>
</head>
<body>

<!-- AUTH SCREEN -->
<div id="auth-screen">
  <div class="auth-box">
    <div class="auth-header">
      <div class="yatra" style="font-size:1.8rem;color:var(--gold)">कलाचौतारी</div>
      <div style="font-size:0.72rem;color:rgba(255,255,255,0.5);text-transform:uppercase;letter-spacing:1px;margin-top:2px">Nepali Creative Hub</div>
    </div>
    <div class="auth-tabs">
      <button class="auth-tab act" onclick="switchAuth('login')">Sign In</button>
      <button class="auth-tab" onclick="switchAuth('register')">Create Account</button>
    </div>
    <div id="auth-login" class="auth-form act">
      <div class="auth-err" id="login-err"></div>
      <div class="fgrp"><label class="flbl">Email</label><input class="finp" id="login-email" type="email" placeholder="your@email.com"/></div>
      <div class="fgrp"><label class="flbl">Password</label><input class="finp" id="login-pw" type="password" placeholder="Password"/></div>
      <button class="btn-p" style="width:100%" onclick="doLogin()">Sign In</button>
      <div class="demo-hint">Demo: aasha@demo.com / demo1234</div>
    </div>
    <div id="auth-register" class="auth-form">
      <div class="auth-err" id="reg-err"></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
        <div class="fgrp"><label class="flbl">Full Name</label><input class="finp" id="reg-name" placeholder="Aasha Gurung"/></div>
        <div class="fgrp"><label class="flbl">Email</label><input class="finp" id="reg-email" type="email" placeholder="email@..."/></div>
      </div>
      <div class="fgrp"><label class="flbl">Password</label><input class="finp" id="reg-pw" type="password" placeholder="Min 8 chars"/></div>
      <div class="fgrp"><label class="flbl">Your Role / Discipline</label><input class="finp" id="reg-role" placeholder="e.g. Singer, Filmmaker, Poet"/></div>
      <div class="fgrp"><label class="flbl">Location</label><input class="finp" id="reg-loc" placeholder="Kathmandu / London / Sydney..."/></div>
      <div class="fgrp"><label class="flbl">Discipline</label>
        <div class="role-pick" id="reg-disc">
          <button class="rp-btn" onclick="toggleRP(this)">Musician</button>
          <button class="rp-btn" onclick="toggleRP(this)">Filmmaker</button>
          <button class="rp-btn" onclick="toggleRP(this)">Writer</button>
          <button class="rp-btn" onclick="toggleRP(this)">Visual Artist</button>
          <button class="rp-btn" onclick="toggleRP(this)">Dancer</button>
          <button class="rp-btn" onclick="toggleRP(this)">Poet</button>
        </div>
      </div>
      <button class="btn-p" style="width:100%;margin-top:0.5rem" onclick="doRegister()">Create Account</button>
    </div>
  </div>
</div>

<!-- MAIN APP -->
<div id="app">
  <div id="nav">
    <a class="logo" href="#" onclick="goPage('discover')">
      <div class="logo-icon yatra">क</div>
      <div>
        <div class="logo-txt yatra"><span class="en-t">Kalachautari</span><span class="np-t np">कलाचौतारी</span></div>
        <div class="logo-sub en-t">Nepali Creative Hub</div>
        <div class="logo-sub np-t np">नेपाली सिर्जना केन्द्र</div>
      </div>
    </a>
    <button class="nav-btn act" data-p="discover"><span class="en-t">Discover</span><span class="np-t np">खोज</span></button>
    <button class="nav-btn" data-p="match"><span class="en-t">Match</span><span class="np-t np">मेल</span></button>
    <button class="nav-btn" data-p="projects"><span class="en-t">Projects</span><span class="np-t np">परियोजना</span></button>
    <button class="nav-btn" data-p="events"><span class="en-t">Events</span><span class="np-t np">कार्यक्रम</span></button>
    <button class="nav-btn" data-p="messages" id="nav-msgs"><span class="en-t">Messages</span><span class="np-t np">सन्देश</span><span class="nav-badge" id="msg-badge" style="display:none">0</span></button>
    <button class="nav-btn" data-p="notifs" id="nav-notifs"><span class="en-t">Notifications</span><span class="np-t np">सूचना</span><span class="nav-badge" id="notif-badge" style="display:none">0</span></button>
    <button class="nav-btn" data-p="profile"><span class="en-t">Profile</span><span class="np-t np">प्रोफाइल</span></button>
    <div class="lang-tog">
      <button class="lng act" onclick="setLang('en')">EN</button>
      <button class="lng" onclick="setLang('np')">ने</button>
    </div>
    <div class="nav-user">
      <div class="nav-av" id="nav-av" onclick="goPage('profile')"></div>
    </div>
    <button class="btn-sm" onclick="doLogout()" style="color:rgba(255,255,255,0.5);border-color:rgba(255,255,255,0.15);font-size:0.68rem">Logout</button>
  </div>

  <!-- DISCOVER -->
  <div id="p-discover" class="page act">
    <div class="hero">
      <div>
        <div style="display:inline-block;background:var(--rust);color:#fff;font-size:0.62rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;padding:2px 9px;border-radius:2px;margin-bottom:0.75rem">Live Platform</div>
        <h1 class="en-t">Where Nepali <span>creatives</span> meet & make</h1>
        <h1 class="np-t np">नेपाली <span>कलाकारहरू</span> भेट्छन् र बनाउँछन्</h1>
        <p class="en-t" style="color:rgba(255,255,255,0.6);font-size:0.83rem;margin-bottom:1.25rem;margin-top:4px">Post a project. Find your tabla player, director, poet. Collaborate from anywhere.</p>
        <div style="display:flex;gap:8px">
          <button class="btn-p" onclick="goPage('post-project')"><span class="en-t">Post a Project</span><span class="np-t np">परियोजना राख्नुस्</span></button>
          <button class="btn-o" style="color:#fff;border-color:rgba(255,255,255,0.25)" onclick="goPage('match')"><span class="en-t">Find Collaborators</span><span class="np-t np">सहयोगी खोज्नुस्</span></button>
        </div>
      </div>
      <div id="hero-stats" style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:1px;background:rgba(255,255,255,0.08)">
        <div style="padding:1.25rem;text-align:center;background:rgba(255,255,255,0.04)"><div class="yatra" style="font-size:1.6rem;color:var(--gold)" id="stat-users">—</div><div style="font-size:0.62rem;color:rgba(255,255,255,0.45);text-transform:uppercase;letter-spacing:1px">Creatives</div></div>
        <div style="padding:1.25rem;text-align:center;background:rgba(255,255,255,0.04)"><div class="yatra" style="font-size:1.6rem;color:var(--gold)" id="stat-projects">—</div><div style="font-size:0.62rem;color:rgba(255,255,255,0.45);text-transform:uppercase;letter-spacing:1px">Projects</div></div>
        <div style="padding:1.25rem;text-align:center;background:rgba(255,255,255,0.04)"><div class="yatra" style="font-size:1.6rem;color:var(--gold)" id="stat-events">—</div><div style="font-size:0.62rem;color:rgba(255,255,255,0.45);text-transform:uppercase;letter-spacing:1px">Events</div></div>
      </div>
    </div>
    <div class="sec-title yatra"><span class="en-t">Browse Creatives</span><span class="np-t np">कलाकारहरू हेर्नुस्</span></div>
    <div class="fbar">
      <input class="srch" id="creator-search" placeholder="Search name, skill…" oninput="loadCreators()"/>
      <button class="fpill act" onclick="setTypeFilter(this,'')" data-type="">All</button>
      <button class="fpill" onclick="setTypeFilter(this,'musician')" data-type="musician"><span class="en-t">Musicians</span><span class="np-t np">संगीत</span></button>
      <button class="fpill" onclick="setTypeFilter(this,'filmmaker')" data-type="filmmaker"><span class="en-t">Film</span><span class="np-t np">फिल्म</span></button>
      <button class="fpill" onclick="setTypeFilter(this,'writer')" data-type="writer"><span class="en-t">Writers</span><span class="np-t np">लेखक</span></button>
      <button class="fpill" onclick="setTypeFilter(this,'visual')" data-type="visual"><span class="en-t">Visual</span><span class="np-t np">दृश्य</span></button>
      <button class="fpill" onclick="setTypeFilter(this,'dancer')" data-type="dancer"><span class="en-t">Dance</span><span class="np-t np">नृत्य</span></button>
    </div>
    <div class="g3" id="creators-grid"><div class="loading">Loading creatives</div></div>
  </div>

  <!-- MATCH -->
  <div id="p-match" class="page">
    <div style="display:grid;grid-template-columns:1fr 280px;gap:1.5rem;align-items:start">
      <div>
        <div class="sec-title yatra"><span class="en-t">Find Your Collaborator</span><span class="np-t np">सहयोगी खोज्नुस्</span></div>
        <div style="background:var(--cream2);border:1px solid var(--border);border-radius:5px;padding:0.875rem;margin-bottom:1rem;font-size:0.77rem;color:var(--muted)">
          <strong style="color:var(--ink)">How it works:</strong> Pass ✕ or Connect ✓. When both connect, messaging unlocks. ★ Super Connect notifies them immediately.
        </div>
        <div id="swipe-area">
          <div class="swipe-stack" id="swipe-stack"></div>
          <div class="sw-actions">
            <button class="sw-btn pass" onclick="swipe('left')">✕</button>
            <button class="sw-btn star" onclick="swipe('super')">★</button>
            <button class="sw-btn conn" onclick="swipe('right')">✓</button>
          </div>
        </div>
        <div id="match-pop-wrap" style="display:none;margin-top:1rem">
          <div class="match-pop">
            <div class="mp-t yatra">सञ्जोग भयो!</div>
            <div style="font-size:0.8rem;color:rgba(255,255,255,0.7);margin-bottom:1rem" class="en-t">It's a match — you can now message each other!</div>
            <div style="display:flex;justify-content:center;gap:8px">
              <button class="btn-p" id="match-msg-btn">Send Message</button>
              <button class="btn-o" style="color:rgba(255,255,255,0.7);border-color:rgba(255,255,255,0.2)" onclick="document.getElementById('match-pop-wrap').style.display='none'">Keep Browsing</button>
            </div>
          </div>
        </div>
      </div>
      <div>
        <div style="background:var(--card);border:1px solid var(--border);border-radius:6px;padding:1rem">
          <div style="font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;color:var(--muted);margin-bottom:0.875rem">Recent Connects</div>
          <div id="recent-connects" style="display:flex;flex-direction:column;gap:6px">
            <div style="font-size:0.75rem;color:var(--muted)">No connects yet — start swiping!</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- PROJECTS -->
  <div id="p-projects" class="page">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem">
      <div class="sec-title yatra" style="margin:0;flex:1"><span class="en-t">Open Collaborations</span><span class="np-t np">खुला सहकार्यहरू</span></div>
      <button class="btn-p" onclick="goPage('post-project')">+ <span class="en-t">Post Project</span><span class="np-t np">परियोजना थप्नुस्</span></button>
    </div>
    <div class="fbar">
      <input class="srch" id="proj-search" placeholder="Search projects…" oninput="loadProjects()"/>
      <button class="fpill act" onclick="setProjFilter(this,'')">All</button>
      <button class="fpill" onclick="setProjFilter(this,'Music')">Music</button>
      <button class="fpill" onclick="setProjFilter(this,'Film')">Film</button>
      <button class="fpill" onclick="setProjFilter(this,'Literature')">Literature</button>
      <button class="fpill" onclick="setProjFilter(this,'Visual Art')">Visual Art</button>
      <button class="fpill" onclick="setProjFilter(this,'remote')">Remote OK</button>
    </div>
    <div class="g2" id="projects-grid"><div class="loading">Loading projects</div></div>
  </div>

  <!-- POST PROJECT -->
  <div id="p-post-project" class="page">
    <div style="max-width:560px;margin:0 auto">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:1rem">
        <button class="btn-sm" onclick="goPage('projects')">← Back</button>
        <div class="sec-title yatra" style="margin:0"><span class="en-t">Post a New Project</span><span class="np-t np">नयाँ परियोजना</span></div>
      </div>
      <div class="step-ind" id="pf-step-ind">
        <div class="step-dot cur"></div><div class="step-dot"></div><div class="step-dot"></div><div class="step-dot"></div>
      </div>
      <div style="background:var(--card);border:1px solid var(--border);border-radius:6px;padding:1.25rem">
        <div class="form-step act" id="pfs1">
          <div style="font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;color:var(--muted);margin-bottom:0.875rem">Step 1 — Basic Info</div>
          <div class="fgrp"><label class="flbl">Project Title *</label><input class="finp" id="pf-title" placeholder="e.g. Himalaya EP, Bato Short Film"/></div>
          <div class="fgrp"><label class="flbl">Nepali Title (optional)</label><input class="finp" id="pf-title-np" placeholder="हिमालय EP"/></div>
          <div class="fgrp"><label class="flbl">Type *</label>
            <select class="finp" id="pf-type">
              <option value="">Select type...</option>
              <option>Music</option><option>Film</option><option>Literature</option>
              <option>Visual Art</option><option>Dance</option><option>Multi-disciplinary</option>
            </select>
          </div>
          <div class="fgrp"><label class="flbl">Description *</label><textarea class="finp" id="pf-desc" placeholder="What is this project about? What makes it unique?"></textarea></div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
            <div class="fgrp"><label class="flbl">Timeline</label><select class="finp" id="pf-timeline"><option>1–4 weeks</option><option>1–3 months</option><option>3–6 months</option><option>Ongoing</option></select></div>
            <div class="fgrp"><label class="flbl">Location</label><input class="finp" id="pf-location" placeholder="Kathmandu / Remote"/></div>
          </div>
          <div class="fgrp" style="display:flex;align-items:center;gap:8px"><input type="checkbox" id="pf-remote" checked/><label for="pf-remote" style="font-size:0.82rem;color:var(--ink)">Remote collaboration welcome</label></div>
          <div class="form-nav"><div></div><button class="btn-p" onclick="pfNext(2)">Next →</button></div>
        </div>
        <div class="form-step" id="pfs2">
          <div style="font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;color:var(--muted);margin-bottom:0.875rem">Step 2 — Roles Needed</div>
          <div class="fgrp"><label class="flbl">Select roles you need</label>
            <div class="role-pick" id="pf-roles">
              <button class="rp-btn" onclick="toggleRP(this)">Vocalist</button>
              <button class="rp-btn" onclick="toggleRP(this)">Guitarist</button>
              <button class="rp-btn" onclick="toggleRP(this)">Tabla Player</button>
              <button class="rp-btn" onclick="toggleRP(this)">Drummer</button>
              <button class="rp-btn" onclick="toggleRP(this)">Bassist</button>
              <button class="rp-btn" onclick="toggleRP(this)">Keyboard</button>
              <button class="rp-btn" onclick="toggleRP(this)">Music Producer</button>
              <button class="rp-btn" onclick="toggleRP(this)">Mixing Engineer</button>
              <button class="rp-btn" onclick="toggleRP(this)">Cinematographer</button>
              <button class="rp-btn" onclick="toggleRP(this)">Video Editor</button>
              <button class="rp-btn" onclick="toggleRP(this)">Sound Designer</button>
              <button class="rp-btn" onclick="toggleRP(this)">Actor</button>
              <button class="rp-btn" onclick="toggleRP(this)">Choreographer</button>
              <button class="rp-btn" onclick="toggleRP(this)">Illustrator</button>
              <button class="rp-btn" onclick="toggleRP(this)">Photographer</button>
              <button class="rp-btn" onclick="toggleRP(this)">Writer / Lyricist</button>
              <button class="rp-btn" onclick="toggleRP(this)">Poet</button>
              <button class="rp-btn" onclick="toggleRP(this)">Translator</button>
            </div>
          </div>
          <div class="fgrp"><label class="flbl">Experience Required</label><select class="finp" id="pf-exp"><option>Any level</option><option>Beginner friendly</option><option>Intermediate+</option><option>Expert only</option></select></div>
          <div class="fgrp"><label class="flbl">Max Collaborators</label><input class="finp" type="number" id="pf-maxcol" value="5" min="1" max="20" style="width:80px"/></div>
          <div class="form-nav">
            <button class="btn-o" onclick="pfNext(1)">← Back</button>
            <button class="btn-p" onclick="pfNext(3)">Next →</button>
          </div>
        </div>
        <div class="form-step" id="pfs3">
          <div style="font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;color:var(--muted);margin-bottom:0.875rem">Step 3 — Media & Links</div>
          <div class="fgrp"><label class="flbl">Reference Links</label><input class="finp" id="pf-link1" placeholder="SoundCloud, YouTube, Behance..." style="margin-bottom:5px"/><input class="finp" id="pf-link2" placeholder="Additional link..."/></div>
          <div class="fgrp"><label class="flbl">Cover Image URL (optional)</label><input class="finp" id="pf-cover" placeholder="https://..."/></div>
          <div style="background:var(--cream2);border-radius:4px;padding:0.875rem;font-size:0.78rem;color:var(--muted)">File upload will be available once deployed with cloud storage (S3/Cloudflare R2). For now, paste links to your existing media.</div>
          <div class="form-nav">
            <button class="btn-o" onclick="pfNext(2)">← Back</button>
            <button class="btn-p" onclick="pfNext(4)">Next →</button>
          </div>
        </div>
        <div class="form-step" id="pfs4">
          <div style="font-size:0.68nm;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;color:var(--muted);margin-bottom:0.875rem">Step 4 — Review & Publish</div>
          <div id="pf-preview" style="background:var(--cream2);border-radius:4px;padding:1rem;margin-bottom:0.875rem;font-size:0.82rem"></div>
          <div style="background:var(--gold-light);border:1px solid rgba(201,146,42,0.3);border-radius:3px;padding:0.75rem;font-size:0.77rem;color:var(--gold2);margin-bottom:0.875rem">
            Once published, interested collaborators can apply. You'll receive an instant notification and choose who to accept.
          </div>
          <div class="form-nav">
            <button class="btn-o" onclick="pfNext(3)">← Back</button>
            <button class="btn-p" id="publish-btn" onclick="publishProject()">Publish Project</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- EVENTS -->
  <div id="p-events" class="page">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem">
      <div class="sec-title yatra" style="margin:0;flex:1"><span class="en-t">Upcoming Events</span><span class="np-t np">आगामी कार्यक्रमहरू</span></div>
      <button class="btn-p" onclick="showCreateEvent()">+ Create Event</button>
    </div>
    <div style="display:flex;flex-direction:column;gap:10px" id="events-list"><div class="loading">Loading events</div></div>
  </div>

  <!-- MESSAGES -->
  <div id="p-messages" class="page">
    <div class="sec-title yatra"><span class="en-t">Messages</span><span class="np-t np">सन्देशहरू</span></div>
    <div class="msg-wrap">
      <div class="msg-layout">
        <div class="conv-list">
          <div class="conv-list-hd"><span>Conversations</span><button class="btn-sm" onclick="showNewConvModal()" style="padding:2px 7px;font-size:0.65rem">+ New</button></div>
          <div id="conv-items"><div class="loading" style="padding:1rem">Loading</div></div>
        </div>
        <div class="chat-main" id="chat-area">
          <div class="empty-conv">
            <div style="font-size:2rem;opacity:0.2;font-family:'Yatra One',serif">क</div>
            <div>Select a conversation or start a new one</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- NOTIFICATIONS -->
  <div id="p-notifs" class="page">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem">
      <div class="sec-title yatra" style="margin:0"><span class="en-t">Notifications</span><span class="np-t np">सूचनाहरू</span></div>
      <button class="btn-sm" onclick="markAllRead()">Mark all read</button>
    </div>
    <div id="notif-list" style="border:1px solid var(--border);border-radius:6px;overflow:hidden"><div class="loading" style="padding:1.5rem">Loading</div></div>
  </div>

  <!-- PROFILE -->
  <div id="p-profile" class="page">
    <div class="prof-wrap">
      <div class="prof-side">
        <div class="prof-banner"><div class="prof-pat"></div><div class="prof-av yatra" id="prof-av-big">आ</div></div>
        <div class="prof-info">
          <div style="font-weight:700;font-size:1rem" id="prof-name">—</div>
          <div style="font-size:0.7rem;color:var(--rust);font-weight:700;text-transform:uppercase;letter-spacing:0.4px;margin-bottom:4px" id="prof-role">—</div>
          <div style="font-size:0.77rem;color:var(--muted);line-height:1.4;margin-bottom:0.875rem" id="prof-bio"></div>
          <div class="p-stats">
            <div class="ps-box"><div class="ps-n" id="prof-stat-proj">—</div><div class="ps-l">Projects</div></div>
            <div class="ps-box"><div class="ps-n" id="prof-stat-collab">—</div><div class="ps-l">Collabs</div></div>
            <div class="ps-box"><div class="ps-n" id="prof-stat-loc">—</div><div class="ps-l">Location</div></div>
          </div>
        </div>
        <div class="p-sec">
          <div class="p-sec-t">Skills</div>
          <div id="prof-skills"></div>
        </div>
        <div class="p-sec">
          <div class="p-sec-t">Genres</div>
          <div id="prof-genres" style="display:flex;flex-wrap:wrap;gap:4px"></div>
        </div>
        <div style="padding:0.875rem 1rem">
          <button class="btn-p" style="width:100%;margin-bottom:6px" onclick="showEditProfile()">Edit Profile</button>
          <button class="btn-o" style="width:100%" onclick="doLogout()">Logout</button>
        </div>
      </div>
      <div>
        <div class="sec-title yatra">My Projects</div>
        <div id="my-projects-list" style="display:flex;flex-direction:column;gap:8px;margin-bottom:1.5rem"></div>
        <div class="sec-title yatra">My Interests Sent</div>
        <div id="my-interests-list" style="display:flex;flex-direction:column;gap:8px"></div>
      </div>
    </div>
  </div>
</div>

<!-- OVERLAY for modals -->
<div class="overlay" id="overlay" style="display:none" onclick="closeOverlay(event)">
  <div class="modal" id="modal-content" onclick="event.stopPropagation()"></div>
</div>

<div id="toast"></div>

<script>
// ── STATE ──────────────────────────────────────────────────────────────────
const S = {
  token: localStorage.getItem('kc_token'),
  user:  JSON.parse(localStorage.getItem('kc_user') || 'null'),
  lang: localStorage.getItem('kc_lang') || 'en',
  currentConv: null,
  swipeCandidates: [],
  swipeIdx: 0,
  recentConnects: [],
  pfStep: 1,
  ws: null,
  projFilter: '',
  typeFilter: '',
};

const API = window.location.origin;

// ── API HELPER ─────────────────────────────────────────────────────────────
async function api(path, opts = {}) {
  const headers = { 'Content-Type': 'application/json' };
  if (S.token) headers['Authorization'] = 'Bearer ' + S.token;
  const r = await fetch(API + '/api' + path, { headers, ...opts, body: opts.body ? JSON.stringify(opts.body) : undefined });
  if (r.status === 401) { doLogout(); return null; }
  return r.json();
}

// ── LANG ───────────────────────────────────────────────────────────────────
function setLang(l) {
  S.lang = l;
  localStorage.setItem('kc_lang', l);
  document.body.classList.toggle('nepali', l === 'np');
  document.querySelectorAll('.lng').forEach(b => b.classList.toggle('act', b.textContent.trim() === (l === 'en' ? 'EN' : 'ने')));
}
setLang(S.lang);

// ── TOAST ──────────────────────────────────────────────────────────────────
function toast(msg, duration = 3500) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), duration);
}

// ── AUTH ───────────────────────────────────────────────────────────────────
function switchAuth(tab) {
  document.querySelectorAll('.auth-tab').forEach((b,i) => b.classList.toggle('act', (i===0) === (tab==='login')));
  document.getElementById('auth-login').classList.toggle('act', tab === 'login');
  document.getElementById('auth-register').classList.toggle('act', tab === 'register');
}

async function doLogin() {
  const email = document.getElementById('login-email').value.trim();
  const pw    = document.getElementById('login-pw').value;
  document.getElementById('login-err').textContent = '';
  if (!email || !pw) return document.getElementById('login-err').textContent = 'Fill in all fields';
  const res = await fetch(API + '/api/auth/login', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ email, password: pw }) });
  const data = await res.json();
  if (!res.ok) return document.getElementById('login-err').textContent = data.error || 'Login failed';
  loginSuccess(data.token, data.user);
}

async function doRegister() {
  const name  = document.getElementById('reg-name').value.trim();
  const email = document.getElementById('reg-email').value.trim();
  const pw    = document.getElementById('reg-pw').value;
  const role  = document.getElementById('reg-role').value.trim();
  const loc   = document.getElementById('reg-loc').value.trim();
  const disciplines = [...document.querySelectorAll('#reg-disc .rp-btn.sel')].map(b => b.textContent.trim().toLowerCase());
  document.getElementById('reg-err').textContent = '';
  if (!name || !email || !pw) return document.getElementById('reg-err').textContent = 'Fill in all required fields';
  if (pw.length < 6) return document.getElementById('reg-err').textContent = 'Password must be at least 6 characters';
  const res = await fetch(API + '/api/auth/register', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ name, email, password: pw, role, location: loc, disciplines }) });
  const data = await res.json();
  if (!res.ok) return document.getElementById('reg-err').textContent = data.error || 'Registration failed';
  loginSuccess(data.token, data.user);
}

function loginSuccess(token, user) {
  S.token = token;
  S.user  = user;
  localStorage.setItem('kc_token', token);
  localStorage.setItem('kc_user', JSON.stringify(user));
  document.getElementById('auth-screen').style.display = 'none';
  document.getElementById('app').style.display = 'block';
  document.getElementById('nav-av').textContent = user.avatar_init || user.name.charAt(0);
  connectWS();
  loadStats();
  loadCreators();
  loadNotifCount();
}

function doLogout() {
  localStorage.removeItem('kc_token');
  localStorage.removeItem('kc_user');
  if (S.ws) S.ws.close();
  location.reload();
}

// ── WEBSOCKET ──────────────────────────────────────────────────────────────
function connectWS() {
  const proto = location.protocol === 'https:' ? 'wss' : 'ws';
  const ws = new WebSocket(`${proto}://${location.host}/ws?token=${S.token}`);
  S.ws = ws;
  ws.onmessage = (e) => {
    const { event, data } = JSON.parse(e.data);
    if (event === 'message' && S.currentConv === data.conv_id) {
      appendMessage(data);
    }
    if (event === 'message') updateConvPreview(data.conv_id, data.content);
    if (event === 'notification') {
      toast('🔔 ' + data.title);
      loadNotifCount();
    }
    if (event === 'new_interest') {
      toast(`New interest in "${data.project_title}" from ${data.user_name}`);
      loadNotifCount();
    }
  };
  ws.onclose = () => setTimeout(connectWS, 3000);
}

// ── NAVIGATION ─────────────────────────────────────────────────────────────
function goPage(p) {
  document.querySelectorAll('.page').forEach(x => x.classList.remove('act'));
  document.querySelectorAll('.nav-btn[data-p]').forEach(b => b.classList.remove('act'));
  const pg = document.getElementById('p-' + p);
  if (pg) pg.classList.add('act');
  const nb = document.querySelector(`.nav-btn[data-p="${p}"]`);
  if (nb) nb.classList.add('act');
  // lazy load
  if (p === 'projects') loadProjects();
  if (p === 'events')   loadEvents();
  if (p === 'messages') loadConversations();
  if (p === 'notifs')   loadNotifications();
  if (p === 'profile')  loadProfile();
  if (p === 'match')    loadMatchCandidates();
  if (p === 'post-project') { S.pfStep = 1; showPfStep(1); }
}
document.querySelectorAll('.nav-btn[data-p]').forEach(b => b.addEventListener('click', () => goPage(b.dataset.p)));

// ── STATS ──────────────────────────────────────────────────────────────────
async function loadStats() {
  const [users, projects, events] = await Promise.all([
    api('/users?limit=1'), api('/projects?status=open'), api('/events')
  ]);
  document.getElementById('stat-users').textContent    = users?.length || 0;
  document.getElementById('stat-projects').textContent = projects?.length || 0;
  document.getElementById('stat-events').textContent   = events?.length || 0;
}

// ── CREATORS ───────────────────────────────────────────────────────────────
let creatorTypeFilter = '';
function setTypeFilter(btn, type) {
  document.querySelectorAll('#p-discover .fpill').forEach(p => p.classList.remove('act'));
  btn.classList.add('act');
  creatorTypeFilter = type;
  loadCreators();
}

async function loadCreators() {
  const search = document.getElementById('creator-search')?.value || '';
  const params = new URLSearchParams();
  if (creatorTypeFilter) params.set('type', creatorTypeFilter);
  if (search) params.set('search', search);
  const users = await api('/users?' + params);
  if (!users) return;
  const grid = document.getElementById('creators-grid');
  if (!users.length) { grid.innerHTML = '<div style="color:var(--muted);font-size:0.85rem">No creatives found.</div>'; return; }
  grid.innerHTML = users.map(u => {
    const disc = JSON.parse(u.disciplines || '[]');
    const color = u.avatar_color || 'rust';
    const skills = JSON.parse(u.skills || '[]').slice(0,3);
    return `<div class="card" style="overflow:hidden">
      <div class="cc-banner ${color}"><div class="cc-pat"></div>
        <div class="cc-av">${u.avatar_init || u.name.charAt(0)}</div>
      </div>
      <div class="cc-body">
        <div class="cc-name">${u.name}</div>
        <div class="cc-role">${u.role}</div>
        <div class="cc-bio">${(u.bio||'').slice(0,90)}${(u.bio||'').length > 90 ? '…' : ''}</div>
        <div style="display:flex;flex-wrap:wrap;gap:3px;margin-bottom:7px">${skills.map(s=>`<span class="tag">${s}</span>`).join('')}</div>
        <div class="cc-foot">
          <span class="cc-loc">${u.location || '—'} · ${u.experience_years || 0}yr</span>
          ${u.id !== S.user?.id ? `<button class="btn-p" style="padding:3px 10px;font-size:0.7rem" onclick="startDMWith('${u.id}','${u.name}')">Connect</button>` : `<span class="tag green">You</span>`}
        </div>
      </div>
    </div>`;
  }).join('');
}

async function startDMWith(userId, name) {
  const res = await api('/conversations', { method: 'POST', body: { target_user_id: userId } });
  if (res?.id) { S.currentConv = res.id; goPage('messages'); loadConversations(); }
}

// ── PROJECTS ───────────────────────────────────────────────────────────────
let projTypeFilter = '', projRemote = false;
function setProjFilter(btn, type) {
  document.querySelectorAll('#p-projects .fpill').forEach(p => p.classList.remove('act'));
  btn.classList.add('act');
  projTypeFilter = type === 'remote' ? '' : type;
  projRemote = type === 'remote';
  loadProjects();
}

async function loadProjects() {
  const search = document.getElementById('proj-search')?.value || '';
  const params = new URLSearchParams();
  if (projTypeFilter) params.set('type', projTypeFilter);
  if (projRemote) params.set('remote', '1');
  if (search) params.set('search', search);
  const projects = await api('/projects?' + params);
  if (!projects) return;
  const grid = document.getElementById('projects-grid');
  if (!projects.length) { grid.innerHTML = '<div style="color:var(--muted);font-size:0.85rem">No projects found.</div>'; return; }
  const typeColor = { Music:'rust', Film:'blue', Literature:'green', 'Visual Art':'gold', Dance:'gold' };
  grid.innerHTML = projects.map(p => {
    const roles = JSON.parse(p.roles_needed || '[]');
    const isOwn = p.owner_id === S.user?.id;
    return `<div class="card" style="overflow:hidden">
      <div class="pc-head">
        <div>
          <div class="pc-title">${p.title}</div>
          <div style="font-size:0.7rem;color:var(--muted)">${p.location || ''}${p.remote_ok ? ' · Remote OK' : ''}</div>
        </div>
        <span class="tag ${typeColor[p.type]||''}">${p.type}</span>
      </div>
      <div class="pc-body">
        <div class="pc-desc">${(p.description||'').slice(0,140)}${(p.description||'').length>140?'…':''}</div>
        <div style="margin-bottom:5px">
          <div style="font-size:0.62rem;font-weight:700;text-transform:uppercase;letter-spacing:0.4px;color:var(--muted);margin-bottom:3px">Looking for</div>
          ${roles.map(r=>`<span class="need">${r}</span>`).join('')}
        </div>
      </div>
      <div class="pc-foot">
        <div style="display:flex;align-items:center;gap:5px">
          <div class="ow-av">${p.owner_init || '?'}</div>
          <span style="font-size:0.72rem;color:var(--muted)">${p.owner_name}</span>
        </div>
        <span style="font-size:0.7rem;color:var(--muted)">${p.interest_count} interested</span>
        ${isOwn
          ? `<button class="btn-sm" onclick="viewProjectInterests('${p.id}','${p.title}')">View Interests</button>`
          : `<button class="btn-g" style="padding:3px 10px;font-size:0.72rem" onclick="showInterestModal('${p.id}','${p.title}')">I'm Interested</button>`
        }
      </div>
    </div>`;
  }).join('');
}

// ── INTEREST MODAL ─────────────────────────────────────────────────────────
function showInterestModal(projectId, projectTitle) {
  showModal(`
    <div class="modal-hd">
      <h3>Express Interest</h3>
      <p>Applying for: <strong>${projectTitle}</strong></p>
    </div>
    <div class="modal-body">
      <div class="fgrp"><label class="flbl">Your Role Offer</label>
        <input class="finp" id="int-role" placeholder="e.g. Tabla player, 8 years experience"/>
      </div>
      <div class="fgrp"><label class="flbl">Message to Owner</label>
        <textarea class="finp" id="int-msg" placeholder="Tell them why you're a great fit…"></textarea>
      </div>
      <div class="fgrp"><label class="flbl">Portfolio / Work Link</label>
        <input class="finp" id="int-link" placeholder="https://soundcloud.com/..."/>
      </div>
    </div>
    <div class="modal-foot">
      <button class="btn-o" onclick="closeOverlay()">Cancel</button>
      <button class="btn-p" onclick="submitInterest('${projectId}')">Send Interest</button>
    </div>
  `);
}

async function submitInterest(projectId) {
  const role  = document.getElementById('int-role')?.value || '';
  const msg   = document.getElementById('int-msg')?.value || '';
  const link  = document.getElementById('int-link')?.value || '';
  const res = await api(`/projects/${projectId}/interest`, { method: 'POST', body: { role_offer: role, message: msg, portfolio_link: link } });
  closeOverlay();
  if (res?.error) return toast('Error: ' + res.error);
  toast('Interest sent! The project owner has been notified.');
  loadProjects();
}

async function viewProjectInterests(projectId, projectTitle) {
  const interests = await api(`/projects/${projectId}/interests`);
  if (!interests) return;
  const rows = interests.length ? interests.map(i => `
    <div style="background:var(--cream2);border-radius:4px;padding:10px 12px;margin-bottom:8px">
      <div style="display:flex;justify-content:space-between;align-items:flex-start">
        <div>
          <div style="font-weight:700;font-size:0.87rem">${i.name}</div>
          <div style="font-size:0.72rem;color:var(--rust);margin-bottom:3px">${i.role_offer || i.role}</div>
          <div style="font-size:0.77rem;color:var(--muted)">${i.message || '(no message)'}</div>
          ${i.portfolio_link ? `<a href="${i.portfolio_link}" target="_blank" style="font-size:0.7rem;color:var(--himalaya)">Portfolio →</a>` : ''}
        </div>
        <span style="font-size:0.68rem;padding:2px 7px;border-radius:10px;background:${i.status==='pending'?'var(--gold-light)':i.status==='accepted'?'var(--green-light)':'var(--cream2)'};color:${i.status==='pending'?'var(--gold2)':i.status==='accepted'?'var(--green)':'var(--muted)'}">${i.status}</span>
      </div>
      ${i.status === 'pending' ? `
        <div style="display:flex;gap:6px;margin-top:8px">
          <button class="btn-p" style="font-size:0.72rem;padding:3px 10px" onclick="respondInterest('${i.id}','accepted','${projectId}','${projectTitle}')">Accept</button>
          <button class="btn-sm" onclick="respondInterest('${i.id}','declined','${projectId}','${projectTitle}')">Decline</button>
        </div>` : ''}
    </div>`).join('') : '<div style="color:var(--muted);font-size:0.83rem">No interests yet.</div>';
  showModal(`
    <div class="modal-hd"><h3>${projectTitle}</h3><p>${interests.length} application${interests.length!==1?'s':''}</p></div>
    <div class="modal-body" style="max-height:60vh;overflow-y:auto">${rows}</div>
    <div class="modal-foot"><button class="btn-o" onclick="closeOverlay()">Close</button></div>
  `);
}

async function respondInterest(interestId, status, projectId, projectTitle) {
  await api(`/interests/${interestId}`, { method: 'PATCH', body: { status } });
  toast(status === 'accepted' ? 'Accepted! A conversation has been created.' : 'Application declined.');
  closeOverlay();
  if (status === 'accepted') { setTimeout(() => { goPage('messages'); loadConversations(); }, 500); }
  else viewProjectInterests(projectId, projectTitle);
}

// ── POST PROJECT FORM ──────────────────────────────────────────────────────
function showPfStep(n) {
  S.pfStep = n;
  document.querySelectorAll('.form-step').forEach(s => s.classList.remove('act'));
  document.getElementById('pfs' + n).classList.add('act');
  document.querySelectorAll('#pf-step-ind .step-dot').forEach((d,i) => {
    d.classList.remove('done','cur');
    if (i < n-1) d.classList.add('done');
    if (i === n-1) d.classList.add('cur');
  });
  if (n === 4) buildProjectPreview();
}

function pfNext(n) {
  if (n > S.pfStep) {
    if (S.pfStep === 1) {
      if (!document.getElementById('pf-title').value.trim()) return toast('Please add a project title');
      if (!document.getElementById('pf-type').value) return toast('Please select a project type');
      if (!document.getElementById('pf-desc').value.trim()) return toast('Please add a description');
    }
  }
  showPfStep(n);
}

function buildProjectPreview() {
  const title   = document.getElementById('pf-title').value || '(untitled)';
  const type    = document.getElementById('pf-type').value || '—';
  const desc    = document.getElementById('pf-desc').value || '(no description)';
  const roles   = [...document.querySelectorAll('#pf-roles .rp-btn.sel')].map(b => b.textContent.trim());
  const loc     = document.getElementById('pf-location').value || 'Not specified';
  const remote  = document.getElementById('pf-remote').checked;
  document.getElementById('pf-preview').innerHTML = `
    <div style="font-weight:700;font-size:1rem;margin-bottom:3px">${title}</div>
    <div style="font-size:0.7rem;color:var(--rust);font-weight:700;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px">${type} · ${loc}${remote?' · Remote OK':''}</div>
    <div style="font-size:0.78rem;color:var(--muted);margin-bottom:8px">${desc}</div>
    <div>${roles.map(r=>`<span class="need">${r}</span>`).join('')}</div>
  `;
}

async function publishProject() {
  const btn = document.getElementById('publish-btn');
  btn.disabled = true;
  btn.textContent = 'Publishing...';
  const title      = document.getElementById('pf-title').value.trim();
  const title_np   = document.getElementById('pf-title-np').value.trim();
  const type       = document.getElementById('pf-type').value;
  const description = document.getElementById('pf-desc').value.trim();
  const roles_needed = [...document.querySelectorAll('#pf-roles .rp-btn.sel')].map(b => b.textContent.trim());
  const timeline   = document.getElementById('pf-timeline').value;
  const location   = document.getElementById('pf-location').value.trim();
  const remote_ok  = document.getElementById('pf-remote').checked;
  const experience_req = document.getElementById('pf-exp').value;
  const max_collaborators = parseInt(document.getElementById('pf-maxcol').value) || 5;
  const link1 = document.getElementById('pf-link1').value;
  const link2 = document.getElementById('pf-link2').value;
  const cover_url = document.getElementById('pf-cover').value;
  const media_links = [link1, link2].filter(Boolean);
  const res = await api('/projects', { method: 'POST', body: { title, title_np, type, description, roles_needed, timeline, location, remote_ok, experience_req, max_collaborators, media_links, cover_url } });
  btn.disabled = false; btn.textContent = 'Publish Project';
  if (res?.error) return toast('Error: ' + res.error);
  toast(`"${title}" is now live! 🎉`);
  goPage('projects');
}

// ── EVENTS ─────────────────────────────────────────────────────────────────
async function loadEvents() {
  const events = await api('/events');
  if (!events) return;
  const list = document.getElementById('events-list');
  if (!events.length) { list.innerHTML = '<div style="color:var(--muted);font-size:0.85rem">No events yet.</div>'; return; }
  list.innerHTML = events.map(e => {
    const d = new Date(e.event_date);
    const day = d.getDate().toString().padStart(2,'0');
    const mon = d.toLocaleString('default',{month:'short'}).toUpperCase();
    const tags = JSON.parse(e.tags || '[]');
    return `<div class="ev-card">
      <div class="ev-date"><div class="ev-day">${day}</div><div class="ev-mon">${mon}</div></div>
      <div class="ev-body">
        <div class="ev-title">${e.title}</div>
        <div class="ev-meta">${e.location} · ${e.event_time || ''}${e.is_online?' · Online':''}</div>
        <div style="display:flex;gap:5px;flex-wrap:wrap;margin-top:4px">
          ${tags.map(t=>`<span class="tag">${t}</span>`).join('')}
          ${e.is_free ? '<span class="tag green">Free</span>' : '<span class="tag gold">Ticketed</span>'}
        </div>
        <div style="font-size:0.72rem;color:var(--muted);margin-top:4px">${e.rsvp_count || 0} attending · By ${e.creator_name || 'Kalachautari'}</div>
      </div>
      <div class="ev-act">
        <button class="btn-p" style="font-size:0.72rem;padding:4px 10px" onclick="showRSVPModal('${e.id}','${e.title.replace(/'/g,"\\'")}','${e.location}','${e.event_date}',${JSON.stringify(e.ticket_tiers).replace(/"/g,'&quot;')})">RSVP</button>
        <button class="btn-sm">Share</button>
      </div>
    </div>`;
  }).join('');
}

function showRSVPModal(eventId, title, location, date, tiersStr) {
  const tiers = JSON.parse(tiersStr.replace(/&quot;/g,'"'));
  showModal(`
    <div class="modal-hd"><h3>${title}</h3><p>${location} · ${date}</p></div>
    <div class="modal-body">
      <div style="font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;color:var(--muted);margin-bottom:8px">Select Ticket</div>
      ${tiers.map((t,i) => `
        <div class="tkt-tier ${i===0?'sel':''}" onclick="this.closest('.modal-body').querySelectorAll('.tkt-tier').forEach(x=>x.classList.remove('sel'));this.classList.add('sel')" data-tier="${t.name}">
          <div><div class="tkt-tier-n">${t.name}</div><div class="tkt-tier-d">${t.desc||''}</div></div>
          <div class="tkt-price">${t.price===0?'Free':'Rs '+t.price}</div>
        </div>`).join('')}
      <div class="fgrp" style="margin-top:0.875rem"><label class="flbl">Quantity</label><input class="finp" type="number" id="rsvp-qty" value="1" min="1" max="10" style="width:80px"/></div>
    </div>
    <div class="modal-foot">
      <button class="btn-o" onclick="closeOverlay()">Cancel</button>
      <button class="btn-p" onclick="confirmRSVP('${eventId}')">Confirm RSVP</button>
    </div>
  `);
}

async function confirmRSVP(eventId) {
  const sel = document.querySelector('#modal-content .tkt-tier.sel');
  const tier = sel?.dataset.tier || 'General';
  const qty  = parseInt(document.getElementById('rsvp-qty')?.value) || 1;
  const res = await api(`/events/${eventId}/rsvp`, { method: 'POST', body: { tier, qty } });
  closeOverlay();
  if (res?.error === 'Already RSVP\'d') return toast('You\'ve already RSVP\'d to this event!');
  toast('RSVP confirmed! Check notifications for your ticket.');
  loadEvents();
}

function showCreateEvent() {
  showModal(`
    <div class="modal-hd"><h3>Create Event</h3><p>It will be visible to all members immediately</p></div>
    <div class="modal-body">
      <div class="fgrp"><label class="flbl">Title *</label><input class="finp" id="ev-title" placeholder="Kala Saanjh — Open Mic"/></div>
      <div class="fgrp"><label class="flbl">Nepali Title</label><input class="finp" id="ev-title-np" placeholder="कला साँझ"/></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
        <div class="fgrp"><label class="flbl">Date *</label><input class="finp" type="date" id="ev-date"/></div>
        <div class="fgrp"><label class="flbl">Time</label><input class="finp" type="time" id="ev-time"/></div>
      </div>
      <div class="fgrp"><label class="flbl">Location</label><input class="finp" id="ev-loc" placeholder="Patan Dhoka / Online"/></div>
      <div class="fgrp"><label class="flbl">Description</label><textarea class="finp" id="ev-desc" placeholder="What's happening?"></textarea></div>
      <div class="fgrp" style="display:flex;gap:12px">
        <label style="display:flex;align-items:center;gap:5px;font-size:0.82rem"><input type="checkbox" id="ev-free" checked/> Free event</label>
        <label style="display:flex;align-items:center;gap:5px;font-size:0.82rem"><input type="checkbox" id="ev-online"/> Online</label>
      </div>
    </div>
    <div class="modal-foot">
      <button class="btn-o" onclick="closeOverlay()">Cancel</button>
      <button class="btn-p" onclick="createEvent()">Create Event</button>
    </div>
  `);
}

async function createEvent() {
  const title = document.getElementById('ev-title')?.value.trim();
  const date  = document.getElementById('ev-date')?.value;
  if (!title || !date) return toast('Title and date required');
  const res = await api('/events', { method: 'POST', body: {
    title, title_np: document.getElementById('ev-title-np')?.value||'',
    description: document.getElementById('ev-desc')?.value||'',
    location: document.getElementById('ev-loc')?.value||'',
    event_date: date, event_time: document.getElementById('ev-time')?.value||'',
    is_free: document.getElementById('ev-free')?.checked ? 1 : 0,
    is_online: document.getElementById('ev-online')?.checked ? 1 : 0,
    ticket_tiers: [{ name:'General', price:0, desc:'Open entry' }],
    tags: []
  }});
  closeOverlay();
  if (res?.error) return toast('Error: ' + res.error);
  toast('Event created and live!');
  loadEvents();
}

// ── MESSAGES ───────────────────────────────────────────────────────────────
async function loadConversations() {
  const convs = await api('/conversations');
  if (!convs) return;
  const list = document.getElementById('conv-items');
  if (!convs.length) { list.innerHTML = '<div style="padding:1rem;font-size:0.78rem;color:var(--muted)">No conversations yet. Connect with a creative or accept an interest!</div>'; return; }
  list.innerHTML = convs.map(c => {
    const other = c.type === 'direct' ? c.members?.find(m => m.id !== S.user?.id) : null;
    const name = c.type === 'group' ? (c.name || 'Group') : (other?.name || 'Unknown');
    const init = c.type === 'group' ? '#' : (other?.avatar_init || '?');
    const isActive = c.id === S.currentConv;
    return `<div class="ci ${isActive?'act':''}" onclick="openConv('${c.id}','${name}','${init}','${c.type}')">
      <div style="display:flex;justify-content:space-between"><span class="ci-name">${name}</span><span class="ci-t">${fmtTime(c.last_time)}</span></div>
      <div class="ci-prev">${c.last_msg || '(no messages yet)'}</div>
    </div>`;
  }).join('');
  if (S.currentConv) {
    const conv = convs.find(c => c.id === S.currentConv);
    if (conv) {
      const other = conv.members?.find(m => m.id !== S.user?.id);
      const name = conv.type === 'group' ? (conv.name || 'Group') : (other?.name || 'Unknown');
      const init = conv.type === 'group' ? '#' : (other?.avatar_init || '?');
      renderChatArea(S.currentConv, name, init, conv.type, conv.members);
    }
  }
}

async function openConv(convId, name, init, type) {
  S.currentConv = convId;
  document.querySelectorAll('.ci').forEach(c => c.classList.remove('act'));
  event?.currentTarget?.classList.add('act');
  const convData = await api('/conversations');
  const conv = convData?.find(c => c.id === convId);
  renderChatArea(convId, name, init, type, conv?.members || []);
}

async function renderChatArea(convId, name, init, type, members) {
  const msgs = await api(`/conversations/${convId}/messages`);
  if (!msgs) return;
  const membersBar = type === 'group' && members.length ? `
    <div style="padding:5px 0.875rem;border-top:1px solid var(--border);display:flex;gap:4px;align-items:center;background:var(--card);flex-shrink:0">
      ${members.map(m=>`<div style="width:22px;height:22px;border-radius:50%;background:var(--cream2);display:flex;align-items:center;justify-content:center;font-size:0.55rem;font-weight:700;color:var(--rust);border:2px solid var(--card)">${m.avatar_init||'?'}</div>`).join('')}
      <span style="font-size:0.68rem;color:var(--muted);margin-left:3px">${members.length} members</span>
    </div>` : '';
  document.getElementById('chat-area').innerHTML = `
    <div class="chat-hd">
      <div class="chat-av ${type==='group'?'grp':''}">${init}</div>
      <div><div style="font-weight:700;font-size:0.85rem">${name}</div><div style="font-size:0.68rem;color:var(--muted)">${type === 'group' ? 'Group Chat' : 'Direct Message'}</div></div>
    </div>
    <div class="chat-msgs" id="msgs-box">
      ${msgs.map(m => renderMsgBubble(m)).join('')}
    </div>
    ${membersBar}
    <div class="chat-inp">
      <input id="chat-input" placeholder="Type a message…" onkeydown="if(event.key==='Enter')sendMsg('${convId}')"/>
      <button class="chat-send" onclick="sendMsg('${convId}')">Send</button>
    </div>
  `;
  const box = document.getElementById('msgs-box');
  if (box) box.scrollTop = box.scrollHeight;
}

function renderMsgBubble(m) {
  const isOut = m.sender_id === S.user?.id;
  const isSys = m.type === 'system';
  if (isSys) return `<div class="msg sys"><div class="mbub">${m.content}</div></div>`;
  return `<div class="msg ${isOut?'out':'in'}">
    ${!isOut && m.sender_name ? `<div style="font-size:0.62rem;color:var(--muted);margin-bottom:2px">${m.sender_name}</div>` : ''}
    <div class="mbub">${m.content}</div>
    <div class="mt">${fmtTime(m.created_at)}</div>
  </div>`;
}

function appendMessage(m) {
  const box = document.getElementById('msgs-box');
  if (!box) return;
  box.insertAdjacentHTML('beforeend', renderMsgBubble(m));
  box.scrollTop = box.scrollHeight;
}

function updateConvPreview(convId, content) {
  const ci = document.querySelector(`.ci[onclick*="${convId}"] .ci-prev`);
  if (ci) ci.textContent = content.slice(0, 50);
}

function sendMsg(convId) {
  const inp = document.getElementById('chat-input');
  if (!inp || !inp.value.trim()) return;
  const content = inp.value.trim();
  inp.value = '';
  if (S.ws && S.ws.readyState === WebSocket.OPEN) {
    S.ws.send(JSON.stringify({ event: 'message', data: { conv_id: convId, content } }));
  }
  // optimistic render
  appendMessage({ sender_id: S.user?.id, sender_name: S.user?.name, type: 'text', content, created_at: new Date().toISOString() });
}

function showNewConvModal() {
  // simplified — just start a DM by email/name lookup
  showModal(`
    <div class="modal-hd"><h3>Start New Conversation</h3><p>Search for a creative to message</p></div>
    <div class="modal-body">
      <div class="fgrp"><label class="flbl">Search by Name</label>
        <input class="finp" id="nc-search" placeholder="Type a name…" oninput="searchNewConv(this.value)"/>
      </div>
      <div id="nc-results" style="display:flex;flex-direction:column;gap:5px;margin-top:8px"></div>
    </div>
    <div class="modal-foot"><button class="btn-o" onclick="closeOverlay()">Cancel</button></div>
  `);
}

async function searchNewConv(q) {
  if (!q.length) return;
  const res = await api('/search?q=' + encodeURIComponent(q));
  const el = document.getElementById('nc-results');
  if (!el || !res) return;
  el.innerHTML = res.users.map(u => `
    <div style="display:flex;align-items:center;gap:8px;padding:7px;background:var(--cream2);border-radius:4px;cursor:pointer" onclick="startDMWith('${u.id}','${u.name}');closeOverlay()">
      <div style="width:28px;height:28px;border-radius:50%;background:var(--cream2);display:flex;align-items:center;justify-content:center;font-size:0.65rem;font-weight:700;color:var(--rust)">${u.avatar_init||u.name.charAt(0)}</div>
      <div><div style="font-size:0.83rem;font-weight:700">${u.name}</div><div style="font-size:0.7rem;color:var(--muted)">${u.role||''}</div></div>
    </div>`).join('') || '<div style="font-size:0.78rem;color:var(--muted)">No results</div>';
}

// ── MATCH / SWIPE ──────────────────────────────────────────────────────────
async function loadMatchCandidates() {
  const candidates = await api('/matches/suggestions');
  if (!candidates) return;
  S.swipeCandidates = candidates;
  S.swipeIdx = 0;
  renderSwipeCards();
}

function renderSwipeCards() {
  const stack = document.getElementById('swipe-stack');
  const remaining = S.swipeCandidates.slice(S.swipeIdx, S.swipeIdx + 2);
  if (!remaining.length) {
    stack.innerHTML = `<div style="display:flex;align-items:center;justify-content:center;height:100%;flex-direction:column;gap:8px;color:var(--muted)">
      <div style="font-size:2.5rem;opacity:0.2;font-family:'Yatra One',serif">✓</div>
      <div style="font-size:0.85rem">You've seen everyone for now!</div>
      <button class="btn-o" style="margin-top:8px" onclick="loadMatchCandidates()">Refresh Suggestions</button>
    </div>`;
    return;
  }
  stack.innerHTML = remaining.map((c, ri) => {
    const skills = JSON.parse(c.skills || '[]').slice(0, 3);
    return `<div class="swipe-card ${ri === 0 ? 'front' : 'back'}">
      <div class="sw-banner ${c.avatar_color||'rust'}"><div class="cc-pat"></div>
        <div class="sw-av">${c.avatar_init || c.name.charAt(0)}</div>
      </div>
      <div class="sw-info">
        <div class="sw-name">${c.name}</div>
        <div class="sw-role">${c.role}</div>
        <div class="match-score"><strong>${c.match_score}% match</strong> — based on genre & discipline</div>
        <div style="font-size:0.78rem;color:var(--muted);line-height:1.4;margin-bottom:8px">${(c.bio||'').slice(0,100)}</div>
        <div style="display:flex;flex-wrap:wrap;gap:3px;margin-bottom:6px">${skills.map(s=>`<span class="tag">${s}</span>`).join('')}</div>
        <div style="font-size:0.7rem;color:var(--muted2)">${c.location || '—'} · ${c.experience_years || 0} yrs exp${c.open_to_remote?' · Remote OK':''}</div>
      </div>
    </div>`;
  }).join('');
}

async function swipe(dir) {
  if (S.swipeIdx >= S.swipeCandidates.length) return;
  const top = document.querySelector('#swipe-stack .swipe-card.front');
  if (!top) return;
  const candidate = S.swipeCandidates[S.swipeIdx];
  if (dir === 'left') top.classList.add('gone-l');
  else {
    top.classList.add('gone-r');
    const res = await api('/matches', { method: 'POST', body: { target_id: candidate.id, type: dir === 'super' ? 'super' : 'connect' } });
    if (res?.matched) {
      S.recentConnects.unshift(candidate);
      renderRecentConnects();
      document.getElementById('match-pop-wrap').style.display = 'block';
      document.getElementById('match-msg-btn').onclick = async () => {
        const c = await api('/conversations', { method: 'POST', body: { target_user_id: candidate.id } });
        if (c?.id) { S.currentConv = c.id; goPage('messages'); loadConversations(); }
        document.getElementById('match-pop-wrap').style.display = 'none';
      };
    }
  }
  S.swipeIdx++;
  setTimeout(() => renderSwipeCards(), 300);
}

function renderRecentConnects() {
  const el = document.getElementById('recent-connects');
  if (!el) return;
  if (!S.recentConnects.length) { el.innerHTML = '<div style="font-size:0.75rem;color:var(--muted)">No connects yet.</div>'; return; }
  el.innerHTML = S.recentConnects.slice(0,4).map(c => `
    <div style="display:flex;align-items:center;gap:7px">
      <div style="width:28px;height:28px;border-radius:50%;background:var(--cream2);display:flex;align-items:center;justify-content:center;font-size:0.65rem;font-weight:700;color:var(--rust)">${c.avatar_init||c.name.charAt(0)}</div>
      <div style="flex:1"><div style="font-size:0.78rem;font-weight:700">${c.name}</div><div style="font-size:0.68rem;color:var(--muted)">${(c.role||'').split('·')[0].trim()}</div></div>
      <button class="btn-sm" style="font-size:0.65rem" onclick="startDMWith('${c.id}','${c.name}')">Chat</button>
    </div>`).join('');
}

// ── NOTIFICATIONS ──────────────────────────────────────────────────────────
async function loadNotifCount() {
  const notifs = await api('/notifications');
  if (!notifs) return;
  const unread = notifs.filter(n => !n.read).length;
  const badge = document.getElementById('notif-badge');
  badge.textContent = unread;
  badge.style.display = unread > 0 ? 'inline' : 'none';
}

async function loadNotifications() {
  const notifs = await api('/notifications');
  if (!notifs) return;
  const list = document.getElementById('notif-list');
  if (!notifs.length) { list.innerHTML = '<div style="padding:1.5rem;text-align:center;color:var(--muted);font-size:0.85rem">No notifications yet</div>'; return; }
  const icons = { interest:'✉', accepted:'✓', declined:'✕', match:'★', rsvp:'🎫', notification:'🔔' };
  list.innerHTML = notifs.map(n => `
    <div class="notif-item ${n.read?'':'unr'}">
      <div class="n-dot ${n.read?'r':''}"></div>
      <div class="n-av">${icons[n.type] || '◉'}</div>
      <div style="flex:1">
        <div style="font-size:0.82rem;font-weight:700;color:var(--ink)">${n.title}</div>
        <div style="font-size:0.75rem;color:var(--muted)">${n.body || ''}</div>
        <div style="font-size:0.65rem;color:var(--muted2);margin-top:2px">${fmtTime(n.created_at)}</div>
      </div>
    </div>`).join('');
}

async function markAllRead() {
  await api('/notifications/read', { method: 'PATCH' });
  loadNotifications();
  loadNotifCount();
}

// ── PROFILE ────────────────────────────────────────────────────────────────
async function loadProfile() {
  const user = await api('/users/' + S.user.id);
  if (!user) return;
  document.getElementById('prof-name').textContent = user.name;
  document.getElementById('prof-role').textContent = user.role;
  document.getElementById('prof-bio').textContent = user.bio || '';
  document.getElementById('prof-av-big').textContent = user.avatar_init || user.name.charAt(0);
  document.getElementById('prof-stat-proj').textContent = user.projects?.length || 0;
  document.getElementById('prof-stat-collab').textContent = user.experience_years + 'yr';
  document.getElementById('prof-stat-loc').textContent = (user.location||'?').split(',')[0];
  const skills = JSON.parse(user.skills || '[]');
  document.getElementById('prof-skills').innerHTML = skills.map(s => `
    <div class="sk-bar"><div class="sk-n"><span>${s}</span></div><div class="sk-track"><div class="sk-fill" style="width:${70+Math.floor(Math.random()*25)}%"></div></div></div>`).join('');
  const genres = JSON.parse(user.genres || '[]');
  document.getElementById('prof-genres').innerHTML = genres.map(g => `<span class="tag rust">${g}</span>`).join('');
  // my projects
  document.getElementById('my-projects-list').innerHTML = (user.projects || []).map(p => `
    <div style="display:flex;align-items:center;gap:8px;padding:8px 10px;background:var(--card);border:1px solid var(--border);border-radius:4px">
      <div style="flex:1"><div style="font-size:0.82rem;font-weight:700">${p.title}</div><div style="font-size:0.7rem;color:var(--muted)">${p.type}</div></div>
      <span class="tag ${p.status==='open'?'green':''}>${p.status}</span>
      <button class="btn-sm" onclick="viewProjectInterests('${p.id}','${p.title}')">Interests</button>
    </div>`).join('') || '<div style="font-size:0.8rem;color:var(--muted)">No projects yet. <button class="btn-sm" onclick="goPage(\'post-project\')">Post one!</button></div>';
}

function showEditProfile() {
  const u = S.user;
  showModal(`
    <div class="modal-hd"><h3>Edit Profile</h3><p>Changes are saved immediately</p></div>
    <div class="modal-body">
      <div class="fgrp"><label class="flbl">Name</label><input class="finp" id="ep-name" value="${u.name||''}"/></div>
      <div class="fgrp"><label class="flbl">Role / Title</label><input class="finp" id="ep-role" value="${u.role||''}" placeholder="Singer, Filmmaker, Poet…"/></div>
      <div class="fgrp"><label class="flbl">Bio</label><textarea class="finp" id="ep-bio">${u.bio||''}</textarea></div>
      <div class="fgrp"><label class="flbl">Location</label><input class="finp" id="ep-loc" value="${u.location||''}"/></div>
      <div class="fgrp"><label class="flbl">Skills (comma separated)</label><input class="finp" id="ep-skills" value="${JSON.parse(u.skills||'[]').join(', ')}"/></div>
      <div class="fgrp"><label class="flbl">Genres (comma separated)</label><input class="finp" id="ep-genres" value="${JSON.parse(u.genres||'[]').join(', ')}"/></div>
    </div>
    <div class="modal-foot">
      <button class="btn-o" onclick="closeOverlay()">Cancel</button>
      <button class="btn-p" onclick="saveProfile()">Save Changes</button>
    </div>
  `);
}

async function saveProfile() {
  const body = {
    name:     document.getElementById('ep-name')?.value.trim(),
    role:     document.getElementById('ep-role')?.value.trim(),
    bio:      document.getElementById('ep-bio')?.value.trim(),
    location: document.getElementById('ep-loc')?.value.trim(),
    skills:   document.getElementById('ep-skills')?.value.split(',').map(s=>s.trim()).filter(Boolean),
    genres:   document.getElementById('ep-genres')?.value.split(',').map(s=>s.trim()).filter(Boolean),
  };
  const res = await api('/users/me', { method: 'PATCH', body });
  closeOverlay();
  if (res?.error) return toast('Error: ' + res.error);
  S.user = { ...S.user, ...res };
  localStorage.setItem('kc_user', JSON.stringify(S.user));
  toast('Profile updated!');
  loadProfile();
}

// ── MODAL HELPERS ──────────────────────────────────────────────────────────
function showModal(html) {
  document.getElementById('modal-content').innerHTML = html;
  document.getElementById('overlay').style.display = 'flex';
}
function closeOverlay(e) {
  if (!e || e.target === document.getElementById('overlay')) {
    document.getElementById('overlay').style.display = 'none';
  }
}

// ── UTILS ──────────────────────────────────────────────────────────────────
function fmtTime(iso) {
  if (!iso) return '';
  const d = new Date(iso), now = new Date();
  const diff = Math.floor((now - d) / 1000);
  if (diff < 60) return 'just now';
  if (diff < 3600) return Math.floor(diff/60) + 'm ago';
  if (diff < 86400) return Math.floor(diff/3600) + 'h ago';
  return d.toLocaleDateString();
}

function toggleRP(btn) { btn.classList.toggle('sel'); }

// ── INIT ───────────────────────────────────────────────────────────────────
if (S.token && S.user) {
  loginSuccess(S.token, S.user);
}
